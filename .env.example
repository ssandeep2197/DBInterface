NODE_ENV=development
LOG_LEVEL=info

# API
API_PORT=8082
SESSION_SECRET=replace-with-a-long-random-string-min-32-chars
SESSION_MAX_AGE_MS=3600000
CORS_ORIGIN=http://localhost:4200
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300

# Public-deployment safety: when true, reject MySQL hosts that resolve to
# private/loopback ranges (10/8, 127/8, 172.16/12, 192.168/16, ::1, etc.).
# Leave false for local dev; set true when the api is internet-facing.
BLOCK_PRIVATE_HOSTS=false

# Set to true if web and api live on different origins (e.g. Vercel + Render).
# Issues cookies as SameSite=None + Secure, which requires HTTPS.
CROSS_SITE_COOKIES=false

# Web
VITE_API_URL=http://localhost:8082
