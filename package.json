{
  "name": "dbinterface",
  "version": "3.0.0",
  "private": true,
  "description": "DBInterface — Nx monorepo: Express + TypeScript API and React + Vite UI for managing a local MySQL instance",
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "api": "nx serve api",
    "web": "nx serve web",
    "dev": "nx run-many -t serve -p api,web --parallel=2",
    "build": "nx run-many -t build",
    "test": "nx run-many -t test",
    "lint": "nx run-many -t lint",
    "typecheck": "nx run-many -t typecheck",
    "format": "prettier --write \"{apps,libs}/**/*.{ts,tsx,js,jsx,json,md,css,html}\"",
    "format:check": "prettier --check \"{apps,libs}/**/*.{ts,tsx,js,jsx,json,md,css,html}\""
  },
  "engines": {
    "node": ">=20.10.0",
    "npm": ">=10.0.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/node": "^20.11.30",
    "@types/react": "^18.2.74",
    "@types/react-dom": "^18.2.24",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.6",
    "@typescript-eslint/eslint-plugin": "^7.5.0",
    "@typescript-eslint/parser": "^7.5.0",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.6",
    "jsdom": "^24.0.0",
    "nx": "^22.7.1",
    "prettier": "^3.2.5",
    "supertest": "^6.3.4",
    "tsc-alias": "^1.8.10",
    "tsx": "^4.7.1",
    "typescript": "^5.4.3",
    "vite": "^6.4.2",
    "vite-tsconfig-paths": "^5.0.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "express-session": "^1.18.0",
    "helmet": "^7.1.0",
    "mysql2": "^3.9.4",
    "pino": "^8.19.0",
    "pino-http": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.3",
    "swagger-ui-express": "^5.0.0",
    "@tanstack/react-query": "^5.28.6",
    "zod": "^3.22.4"
  },
  "overrides": {
    "axios": "^1.16.0",
    "follow-redirects": "^1.16.0",
    "yaml": "^2.8.4",
    "nx": {
      "brace-expansion": "^5.0.5"
    }
  }
}
