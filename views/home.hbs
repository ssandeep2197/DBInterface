<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="DBInterface — Tables in {{dbName}}">
  <title>DBInterface — {{dbName}}</title>
  <link rel="icon" href="/favicon.ico" type="image/x-icon">
  <link rel="stylesheet" href="/design.css">
  <link rel="stylesheet" href="/homePageStyle.css">
</head>

<body>

  <!-- Header -->
  <header class="app-header">
    <a href="/databases" class="logo">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
        stroke-linecap="round" stroke-linejoin="round">
        <ellipse cx="12" cy="5" rx="9" ry="3" />
        <path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3" />
        <path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5" />
      </svg>
      DBInterface
    </a>
    <div class="breadcrumb">
      <span class="sep">/</span>
      <a href="/databases">Databases</a>
      <span class="sep">/</span>
      <span class="current" id="db" class="{{dbName}}">{{dbName}}</span>
    </div>
    <div class="header-right">
      <select id="db_list" class="select db-select" onchange="dbSwitch()" aria-label="Switch database">
        <option value="{{dbName}}" selected>{{dbName}}</option>
      </select>
      <form action="/logout" method="get" style="display:inline">
        <button class="btn btn-ghost btn-sm" type="submit" id="logout-btn">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
            stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
            <polyline points="16 17 21 12 16 7" />
            <line x1="21" y1="12" x2="9" y2="12" />
          </svg>
          Logout
        </button>
      </form>
    </div>
  </header>

  <!-- Layout: Sidebar + Main -->
  <div class="layout">

    <!-- Sidebar -->
    <aside class="sidebar">
      <div class="sidebar-header">
        <span>Tables</span>
        <span class="badge badge-system">{{allTables.length}}</span>
      </div>
      <nav class="table-nav" id="table-nav">
        {{#each allTables as |table|}}
        <a href="/table/{{table}}/" class="table-nav-item" id="nav-{{table}}">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
            stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="18" height="18" rx="2" ry="2" />
            <line x1="3" y1="9" x2="21" y2="9" />
            <line x1="3" y1="15" x2="21" y2="15" />
            <line x1="9" y1="9" x2="9" y2="21" />
            <line x1="15" y1="9" x2="15" y2="21" />
          </svg>
          {{table}}
        </a>
        {{/each}}
        {{#unless allTables.length}}
        <p class="sidebar-empty">No tables yet</p>
        {{/unless}}
      </nav>
    </aside>

    <!-- Main content -->
    <main class="main-content">
      <div class="main-inner">

        <!-- Table cards grid -->
        {{#if allTables.length}}
        <div class="section-header-row">
          <h2 class="page-title">Tables in <span class="text-accent">{{dbName}}</span></h2>
          <button class="btn btn-primary" id="add-table">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
              stroke-linecap="round" stroke-linejoin="round">
              <line x1="12" y1="5" x2="12" y2="19" />
              <line x1="5" y1="12" x2="19" y2="12" />
            </svg>
            New Table
          </button>
        </div>
        <div class="table-card-grid">
          {{#each allTables as |table|}}
          <a href="/table/{{table}}/" class="table-card">
            <div class="table-card-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"
                stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2" />
                <line x1="3" y1="9" x2="21" y2="9" />
                <line x1="3" y1="15" x2="21" y2="15" />
                <line x1="9" y1="9" x2="9" y2="21" />
                <line x1="15" y1="9" x2="15" y2="21" />
              </svg>
            </div>
            <div class="table-card-name">{{table}}</div>
            <svg class="table-card-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="9 18 15 12 9 6" />
            </svg>
          </a>
          {{/each}}
        </div>
        {{else}}
        <div class="main-empty">
          <div class="main-empty-icon">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"
              stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="18" height="18" rx="2" ry="2" />
              <line x1="3" y1="9" x2="21" y2="9" />
              <line x1="9" y1="9" x2="9" y2="21" />
            </svg>
          </div>
          <h3>No tables in {{dbName}}</h3>
          <p>Create your first table to get started.</p>
          <button class="btn btn-primary mt-3" id="add-table">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
              stroke-linecap="round" stroke-linejoin="round">
              <line x1="12" y1="5" x2="12" y2="19" />
              <line x1="5" y1="12" x2="19" y2="12" />
            </svg>
            Create Table
          </button>
        </div>
        {{/if}}

      </div>
    </main>
  </div>

  <!-- Create Table Slide-Out Panel -->
  <div class="panel-overlay" id="panel-overlay"></div>
  <aside class="create-panel" id="create-panel" aria-hidden="true">
    <div class="create-panel-header">
      <h2>Create New Table</h2>
      <button class="modal-close" id="panel-close">✕</button>
    </div>
    <div class="create-panel-body">

      <form action="/api/createTable/{{dbName}}" id="form" method="POST">
        <div class="field-row mb-3">
          <label class="field-label" for="tableName">Table Name</label>
          <input type="text" name="tableName" class="input" id="tableName" placeholder="e.g. users" required
            autocomplete="off" spellcheck="false">
          <p class="text-danger mt-1" id="warn" style="font-size:13px;display:none">A table with this name already
            exists.</p>
        </div>

        <div class="col-actions">
          <button type="button" id="add" class="btn btn-secondary btn-sm">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
              stroke-linecap="round" stroke-linejoin="round">
              <line x1="12" y1="5" x2="12" y2="19" />
              <line x1="5" y1="12" x2="19" y2="12" />
            </svg>
            Add Column
          </button>
          <button type="button" id="del" class="btn btn-ghost btn-sm">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
              stroke-linecap="round" stroke-linejoin="round">
              <polyline points="3 6 5 6 21 6" />
              <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" />
              <path d="M10 11v6" />
              <path d="M14 11v6" />
            </svg>
            Remove Last
          </button>
        </div>

        <!-- Column count hidden field -->
        <input type="number" id="tcol" name="totalColumns" value="0" hidden>

        <!-- Columns container -->
        <div id="col-container" class="col-container"></div>

        <p class="column-count-label">Columns: <strong id="i">0</strong></p>

        <div id="pre-table"></div>

        <div class="panel-actions">
          <button type="reset" class="btn btn-ghost" id="btn-reset">Reset</button>
          <button type="submit" class="btn btn-primary" id="create_btn">Create Table</button>
        </div>
      </form>

    </div>
  </aside>

  <div class="toast-container" id="toast-container"></div>

  <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
  <script src="/homeScript.js"></script>
</body>

</html>