<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="DBInterface — {{tableName}} table data">
  <title>DBInterface — {{tableName}}</title>
  <link rel="icon" href="/favicon.ico" type="image/x-icon">
  <link rel="stylesheet" href="/design.css">
  <link rel="stylesheet" href="/showPageStyle.css">
</head>

<body>

  <!-- Header / Nav -->
  <header class="app-header">
    <a href="/databases" class="logo">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
        stroke-linecap="round" stroke-linejoin="round">
        <ellipse cx="12" cy="5" rx="9" ry="3" />
        <path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3" />
        <path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5" />
      </svg>
      DBInterface
    </a>
    <div class="breadcrumb">
      <span class="sep">/</span>
      <a href="/databases">Databases</a>
      <span class="sep">/</span>
      <a href="/{{db}}/db" id="db-crumb">{{db}}</a>
      <span class="sep">/</span>
      <span class="current">{{tableName}}</span>
    </div>
    <div class="header-right">
      <select id="db_list" class="select db-select" onchange="dbSwitch()" aria-label="Switch database">
        <option value="{{db}}" selected>{{db}}</option>
      </select>
      <form action="/logout" method="get" style="display:inline">
        <button class="btn btn-ghost btn-sm" type="submit" id="logout-btn">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
            stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
            <polyline points="16 17 21 12 16 7" />
            <line x1="21" y1="12" x2="9" y2="12" />
          </svg>
          Logout
        </button>
      </form>
    </div>
  </header>

  <!-- Page body -->
  <div class="show-layout">

    <!-- Toolbar: table name + search -->
    <div class="show-toolbar">
      <div class="title-block">
        <h1 class="table-heading" id="head">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
            stroke-linecap="round" stroke-linejoin="round" style="color:var(--accent)">
            <rect x="3" y="3" width="18" height="18" rx="2" ry="2" />
            <line x1="3" y1="9" x2="21" y2="9" />
            <line x1="3" y1="15" x2="21" y2="15" />
            <line x1="9" y1="9" x2="9" y2="21" />
            <line x1="15" y1="9" x2="15" y2="21" />
          </svg>
          <input id="title" value="{{tableName}}" name="{{tableName}}" class="title-input" spellcheck="false"
            autocomplete="off">
          <button id="change-btn" class="btn btn-secondary btn-sm save-title-btn" style="display:none">Save
            name</button>
        </h1>
      </div>

      <!-- Column header editor -->
      <div class="col-header-strip" id="table">
        {{#each tableSchema as |s|}}
        <input onmouseover="hoverCol('{{s.Field}}')" id="{{s.Field}}" onclick="colums('{{s.Field}}')"
          value="{{s.Field}}" class="table-entry" spellcheck="false" autocomplete="off">
        {{/each}}
        <button id="col-edit" class="btn btn-secondary btn-sm" style="display:none">Save column</button>
      </div>

      <!-- Search bar -->
      <div class="search-bar">
        <div class="search-input-wrap">
          <svg class="search-icon-svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8" />
            <line x1="21" y1="21" x2="16.65" y2="16.65" />
          </svg>
          <input id="search_data" class="search-input" placeholder="Search…" autocomplete="off" spellcheck="false">
          <button id="cross-icon" class="clear-search-btn" style="display:none" title="Clear search"
            aria-label="Clear search">✕</button>
        </div>
        <select id="select" class="select search-type-select">
          <option value="1" selected>Column…</option>
        </select>
        <button id="search-icon" class="btn btn-secondary btn-sm">Search</button>
      </div>
    </div>

    <!-- Alert bar -->
    <section id="alert-box" style="display:none">
      <div class="alert-bar">
        <span class="alert-msg" id="alert-msg-text">Warning:</span>
        <button class="alert-close" id="alert-close-btn">✕</button>
      </div>
    </section>

    <!-- Data table -->
    <div class="table-area">
      <div class="data-table-wrap">
        <table class="data-table" id="table1"></table>
      </div>
      <p id="emt" class="empty-label" style="display:none">{{isTableEmptyString}}</p>
      <p id="found" class="empty-label" style="display:none">No results found.</p>
    </div>

  </div>

  <!-- Action bar (sticky bottom) -->
  <div class="action-bar" id="buttons">
    <button id="insert" class="btn btn-secondary">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
        stroke-linecap="round" stroke-linejoin="round">
        <line x1="12" y1="5" x2="12" y2="19" />
        <line x1="5" y1="12" x2="19" y2="12" />
      </svg>
      Add Row
    </button>
    <button id="add_data" class="btn btn-primary">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
        stroke-linecap="round" stroke-linejoin="round">
        <polyline points="20 6 9 17 4 12" />
      </svg>
      Save Rows
    </button>
    <div id="btnexport" class="btn btn-secondary">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
        stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
        <polyline points="7 10 12 15 17 10" />
        <line x1="12" y1="15" x2="12" y2="3" />
      </svg>
      Export PDF
    </div>
    <form action="/api/delete/{{tableName}}" id="del-form" method="post" style="display:inline">
      <button id="del-data" class="btn btn-secondary">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
          stroke-linecap="round" stroke-linejoin="round">
          <polyline points="3 6 5 6 21 6" />
          <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" />
        </svg>
        Clear Data
      </button>
    </form>
    <form action="/api/{{db}}/deleteTable/{{tableName}}" id="cnl-form" method="post" style="display:inline">
      <button id="del" class="btn btn-danger">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
          stroke-linecap="round" stroke-linejoin="round">
          <polyline points="3 6 5 6 21 6" />
          <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" />
          <path d="M10 11v6" />
          <path d="M14 11v6" />
        </svg>
        Delete Table
      </button>
    </form>
  </div>

  <!-- Row Edit Modal -->
  <div class="modal-overlay" id="updatebox">
    <div class="modal wrapper" role="dialog" aria-modal="true" aria-labelledby="update-modal-title">
      <div class="modal-header" id="drag">
        <h2 id="update-modal-title">Edit Row</h2>
        <button class="modal-close" onclick="cancelEdit()" aria-label="Close">✕</button>
      </div>
      <div class="modal-body" id="box"></div>
      <div class="modal-footer action-btn">
        <button class="btn btn-danger btn-sm" onclick="delete_entry()">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
            stroke-linecap="round" stroke-linejoin="round">
            <polyline points="3 6 5 6 21 6" />
            <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" />
          </svg>
          Delete
        </button>
        <button class="btn btn-ghost btn-sm" onclick="copyEntry()">Copy JSON</button>
        <button class="btn btn-ghost btn-sm" onclick="cancelEdit()">Cancel</button>
        <button class="btn btn-primary btn-sm" onclick="update()">Update</button>
      </div>
    </div>
  </div>

  <!-- Confirm Dialog -->
  <div class="modal-overlay" id="confirm-overlay">
    <div class="modal confirm-modal" role="dialog" aria-modal="true">
      <div class="modal-header">
        <h2 id="confirm-title">Confirm</h2>
      </div>
      <div class="modal-body">
        <p id="confirm-message" style="font-size:14px;color:var(--text-secondary)"></p>
      </div>
      <div class="modal-footer">
        <button class="btn btn-ghost" id="confirm-no">Cancel</button>
        <button class="btn btn-danger" id="confirm-yes">Confirm</button>
      </div>
    </div>
  </div>

  <div class="toast-container" id="toast-container"></div>

  <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
  <script type="text/javascript" src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.1.22/pdfmake.min.js"></script>
  <script type="text/javascript"
    src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/0.4.1/html2canvas.min.js"></script>
  <script src="/showScript.js"></script>
</body>

</html>