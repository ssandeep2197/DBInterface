<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="DBInterface — Select a MySQL database">
    <title>DBInterface — Databases</title>
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
    <link rel="stylesheet" href="/design.css">
    <link rel="stylesheet" href="/style_hbs.css">
</head>

<body>

    <!-- Header -->
    <header class="app-header">
        <a href="/databases" class="logo">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                stroke-linecap="round" stroke-linejoin="round">
                <ellipse cx="12" cy="5" rx="9" ry="3" />
                <path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3" />
                <path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5" />
            </svg>
            DBInterface
        </a>
        <div class="breadcrumb">
            <span class="sep">/</span>
            <span class="current">Databases</span>
        </div>
        <div class="header-right">
            <form action="/logout" method="get" style="display:inline">
                <button class="btn btn-ghost btn-sm" type="submit" id="logout-btn">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                        stroke-linecap="round" stroke-linejoin="round">
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                        <polyline points="16 17 21 12 16 7" />
                        <line x1="21" y1="12" x2="9" y2="12" />
                    </svg>
                    Logout
                </button>
            </form>
        </div>
    </header>

    <!-- Page content -->
    <div class="page-content">

        <!-- User Databases -->
        <section class="db-section">
            <div class="section-header">
                <div>
                    <h2 class="section-title">Your Databases</h2>
                    <p class="section-sub">Click a database to explore its tables</p>
                </div>
                <button class="btn btn-primary btn-sm" id="create-db-btn">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                        stroke-linecap="round" stroke-linejoin="round">
                        <line x1="12" y1="5" x2="12" y2="19" />
                        <line x1="5" y1="12" x2="19" y2="12" />
                    </svg>
                    New Database
                </button>
            </div>

            {{#if databases.length}}
            <div class="db-grid" id="user-db-grid">
                {{#each databases as |database|}}
                <a href="/{{database}}/db" class="db-card" id="db-card-{{database}}">
                    <div class="db-card-icon">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <ellipse cx="12" cy="5" rx="9" ry="3" />
                            <path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3" />
                            <path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5" />
                        </svg>
                    </div>
                    <div class="db-card-body">
                        <div class="db-card-name">{{database}}</div>
                        <span class="badge badge-user">User</span>
                    </div>
                    <svg class="db-card-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="9 18 15 12 9 6" />
                    </svg>
                </a>
                {{/each}}
            </div>
            {{else}}
            <div class="empty-state">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"
                    stroke-linecap="round" stroke-linejoin="round" style="color:var(--text-muted);margin-bottom:12px">
                    <ellipse cx="12" cy="5" rx="9" ry="3" />
                    <path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3" />
                    <path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5" />
                </svg>
                <p>No user databases found.</p>
                <button class="btn btn-primary btn-sm mt-3" id="create-db-btn-2">Create your first database</button>
            </div>
            {{/if}}
        </section>

        <!-- System Databases -->
        <section class="db-section">
            <details class="sys-details">
                <summary class="sys-summary">
                    <span>System Databases</span>
                    <span class="badge badge-system">{{systemDatabases.length}}</span>
                    <svg class="chevron-icon" width="14" height="14" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="6 9 12 15 18 9" />
                    </svg>
                </summary>
                <div class="sys-db-list">
                    {{#each systemDatabases as |database|}}
                    <div class="sys-db-item">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                            style="color:var(--text-muted)">
                            <ellipse cx="12" cy="5" rx="9" ry="3" />
                            <path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3" />
                            <path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5" />
                        </svg>
                        {{database}}
                        <span class="badge badge-system" style="margin-left:auto">System</span>
                    </div>
                    {{/each}}
                </div>
            </details>
        </section>

    </div>

    <!-- Create Database Modal -->
    <div class="modal-overlay" id="create-db-modal">
        <div class="modal" role="dialog" aria-modal="true" aria-labelledby="modal-title">
            <div class="modal-header">
                <h2 id="modal-title">Create New Database</h2>
                <button class="modal-close" id="modal-close-btn" aria-label="Close">✕</button>
            </div>
            <div class="modal-body">
                <label class="field-label" for="new-db-name">Database Name</label>
                <input type="text" id="new-db-name" class="input" placeholder="e.g. my_project_db" autocomplete="off"
                    spellcheck="false">
                <p class="text-muted mt-2" style="font-size:13px">Use only letters, numbers, and underscores.</p>
                <p class="text-danger mt-2" id="create-db-error" style="font-size:13px;display:none"></p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-ghost" id="modal-cancel-btn">Cancel</button>
                <button class="btn btn-primary" id="modal-create-btn">Create Database</button>
            </div>
        </div>
    </div>

    <div class="toast-container" id="toast-container"></div>

    <!-- hidden server url for JS -->
    <p id="server_url" style="display:none">{{server}}</p>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="/databasePageScript.js"></script>
</body>

</html>